    <!-- Info tips -->
    <string name="tip_your_gauge_title">Hvad er strikkefasthed?</string>
    <string name="tip_your_gauge_desc">Strikkefasthed fortæller, hvor mange masker og pinde der passer inden for et målt område. Strik en lille prøve og mål den for at finde din personlige strikkefasthed. Det sikrer, at dit færdige arbejde passer til opskriftens tilsigtede størrelse.</string>
    <string name="tip_swatch_vs_direct_title">Strikkeprøve vs. direkte indtastning</string>
    <string name="tip_swatch_vs_direct_desc">Brug \"Mål strikkeprøve\", hvis du har strikket en prøve og vil måle den. Brug \"Indtast direkte\", hvis du allerede kender din strikkefasthed (f.eks. 22 masker pr. 10 cm).</string>
    <string name="tip_pattern_repeat_title">Mønsterrapport</string>
    <string name="tip_pattern_repeat_desc">Hvis dit mønster gentager sig for hver X masker (f.eks. en snoning for hver 8 masker), skal du indtaste tallet her. Beregneren runder opslagningen til nærmeste multiplum, så mønsteret passer perfekt.</string>
    <string name="tip_edge_stitches_title">Kantmasker</string>
    <string name="tip_edge_stitches_desc">Kantmasker er ekstra masker i hver side for en pæn kant. De er ikke en del af mønsterrapporten. Almindelige værdier er 1–2 masker pr. side.</string>
    <string name="tip_flat_vs_circular_title">Fladstrik vs. rundstrik</string>
    <string name="tip_flat_vs_circular_desc">Ved fladstrik arbejder du frem og tilbage på lige eller rundpinde og vender ved slutningen af hver pind. Udtagninger og indtagninger sker i begge sider.\n\nVed rundstrik arbejder du i en sammenhængende omgang. Udtagninger og indtagninger fordeles jævnt rundt på omgangen.</string>
    <string name="tip_pattern_repeat_pill_title">Tæller for mønsterrapporter</string>
    <string name="tip_pattern_repeat_pill_desc">Denne tæller, hvor mange gange du har gennemført en mønstersektion. Den nulstilles automatisk ud fra dit gentagelsesinterval. Nyttig til at følge snoninger, hulmønstre eller farveskift.</string>
    <string name="tip_needle_sizes_title">Systemer for pindestørrelser</string>
    <string name="tip_needle_sizes_desc">Metrisk (mm) er den universelle standard. US-størrelser bruger et nummersystem (0–50). UK/Canada bruger et andet nummersystem. Japanske størrelser har deres egen nummerering. Tjek altid mm-størrelsen for at være sikker.</string>
    <string name="tip_imperial_units_title">Imperiale enheder</string>
    <string name="tip_imperial_units_desc">Når dette er slået til, bruger alle beregnere tommer i stedet for centimeter og yard i stedet for meter. Strikkefastheden måles da pr. 4 tommer i stedet for pr. 10 cm.</string>
</resources>
