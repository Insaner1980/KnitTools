    <!-- Info tips -->
    <string name="tip_your_gauge_title">Hva er fasthet?</string>
    <string name="tip_your_gauge_desc">Fasthet forteller hvor mange masker og rader som får plass innenfor et målt område. Strikk en liten prøvelapp og mål den for å finne din personlige fasthet. Da blir sluttresultatet i riktig størrelse i forhold til oppskriften.</string>
    <string name="tip_swatch_vs_direct_title">Prøvelapp vs. direkte innskriving</string>
    <string name="tip_swatch_vs_direct_desc">Bruk \"Mål prøvelapp\" hvis du har strikket en testlapp og vil måle den. Bruk \"Skriv inn direkte\" hvis du allerede kjenner fastheten din (f.eks. 22 masker per 10 cm).</string>
    <string name="tip_pattern_repeat_title">Mønsterrapport</string>
    <string name="tip_pattern_repeat_desc">Hvis mønsteret ditt gjentas hver X masker (f.eks. en flette hver 8. maske), skriver du inn tallet her. Kalkulatoren avrunder opplegget til nærmeste multiplum, slik at mønsteret passer perfekt.</string>
    <string name="tip_edge_stitches_title">Kantmasker</string>
    <string name="tip_edge_stitches_desc">Kantmasker er ekstra masker i hver side for en pen kant. De er ikke en del av mønsterrepetisjonen. Vanlige verdier er 1–2 masker per side.</string>
    <string name="tip_flat_vs_circular_title">Flatstrikk vs. rundstrikk</string>
    <string name="tip_flat_vs_circular_desc">Ved flatstrikk strikker du frem og tilbake på rette eller rundpinner og snur ved slutten av hver rad. Økninger og fellinger skjer i begge kanter.\n\nVed rundstrikk strikker du i en sammenhengende omgang. Økninger og fellinger fordeles jevnt rundt omgangen.</string>
    <string name="tip_pattern_repeat_pill_title">Teller for mønsterrapporter</string>
    <string name="tip_pattern_repeat_pill_desc">Denne teller hvor mange ganger du har fullført en mønsterseksjon. Den nullstilles automatisk ut fra repetisjonsintervallet ditt. Nyttig for å følge fletteskift, hullmønstre eller fargeskift.</string>
    <string name="tip_needle_sizes_title">Systemer for pinnestørrelser</string>
    <string name="tip_needle_sizes_desc">Metrisk (mm) er den universelle standarden. US-størrelser bruker et nummersystem (0–50). UK/Canada bruker et annet nummersystem. Japanske størrelser har sin egen nummerering. Sjekk alltid mm-størrelsen for å være sikker.</string>
    <string name="tip_imperial_units_title">Britiske/amerikanske enheter</string>
    <string name="tip_imperial_units_desc">Når dette er aktivert, bruker alle kalkulatorer tommer i stedet for centimeter og yard i stedet for meter. Fastheten måles da per 4 tommer i stedet for per 10 cm.</string>
</resources>
