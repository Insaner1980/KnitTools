    <!-- Info tips -->
    <string name="tip_your_gauge_title">¿Qué es la muestra?</string>
    <string name="tip_your_gauge_desc">La muestra te indica cuántos puntos y vueltas caben en un área medida. Teje una pequeña muestra y mídela para conocer tu tensión personal. Así te aseguras de que la prenda terminada tenga el tamaño previsto en el patrón.</string>
    <string name="tip_swatch_vs_direct_title">Muestra frente a introducción directa</string>
    <string name="tip_swatch_vs_direct_desc">Usa "Medir muestra" si has tejido una muestra y quieres medirla. Usa "Introducir directamente" si ya conoces tu tensión (por ejemplo, 22 puntos por 10 cm).</string>
    <string name="tip_pattern_repeat_title">Repetición del patrón</string>
    <string name="tip_pattern_repeat_desc">Si tu motivo se repite cada X puntos (por ejemplo, una trenza cada 8 puntos), introduce ese número aquí. La calculadora redondeará el número de puntos montados al múltiplo más cercano para que el patrón encaje perfectamente.</string>
    <string name="tip_edge_stitches_title">Puntos de borde</string>
    <string name="tip_edge_stitches_desc">Los puntos de borde son puntos extra añadidos a cada lado para conseguir un orillo limpio. No forman parte de la repetición del patrón. Valores habituales: 1–2 puntos por lado.</string>
    <string name="tip_flat_vs_circular_title">Plano frente a circular</string>
    <string name="tip_flat_vs_circular_desc">Tejido plano: trabajas de ida y vuelta con agujas rectas o circulares, girando al final de cada vuelta. Los aumentos y disminuciones ocurren en ambos bordes.\n\nTejido circular: trabajas en una vuelta continua. Los aumentos y disminuciones se reparten uniformemente alrededor de la vuelta.</string>
    <string name="tip_pattern_repeat_pill_title">Contador de repeticiones del patrón</string>
    <string name="tip_pattern_repeat_pill_desc">Esto cuenta cuántas veces has completado una sección de repetición del patrón. Se restablece automáticamente según tu intervalo de repetición. Es útil para seguir giros de trenzas, repeticiones de encaje o cambios de color.</string>
    <string name="tip_needle_sizes_title">Sistemas de tallas de agujas</string>
    <string name="tip_needle_sizes_desc">El sistema métrico (mm) es el estándar universal. Las tallas US usan un sistema numerado (0–50). Las tallas UK/Canadá usan un sistema numerado diferente. Las tallas japonesas tienen su propia numeración. Comprueba siempre la medida en mm para asegurarte.</string>
    <string name="tip_imperial_units_title">Unidades imperiales</string>
    <string name="tip_imperial_units_desc">Cuando está activado, todas las calculadoras usan pulgadas en lugar de centímetros y yardas en lugar de metros. La muestra se mide por 4 pulgadas en lugar de por 10 cm.</string>
</resources>
