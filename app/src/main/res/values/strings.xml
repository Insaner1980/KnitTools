    <!-- Info tips -->
    <string name="tip_your_gauge_title">What is gauge?</string>
    <string name="tip_your_gauge_desc">Gauge tells you how many stitches and rows fit in a measured area. Knit a small sample (swatch) and measure it to find your personal gauge. This ensures your finished piece matches the pattern\'s intended size.</string>
    <string name="tip_swatch_vs_direct_title">Swatch vs. direct entry</string>
    <string name="tip_swatch_vs_direct_desc">Use \"Measure swatch\" if you\'ve knitted a test piece and want to measure it. Use \"Enter directly\" if you already know your gauge (e.g. 22 stitches per 10 cm).</string>
    <string name="tip_pattern_repeat_title">Pattern repeat</string>
    <string name="tip_pattern_repeat_desc">If your stitch pattern repeats every X stitches (e.g. a cable every 8 stitches), enter that number here. The calculator will round the cast-on count to the nearest multiple so your pattern aligns perfectly.</string>
    <string name="tip_edge_stitches_title">Edge stitches</string>
    <string name="tip_edge_stitches_desc">Edge stitches are extra stitches added at each side for a clean selvedge. They\'re not part of the pattern repeat. Common values: 1–2 stitches per side.</string>
    <string name="tip_flat_vs_circular_title">Flat vs. circular</string>
    <string name="tip_flat_vs_circular_desc">Flat knitting: you work back and forth on straight or circular needles, turning at the end of each row. Increases/decreases happen at both edges.\n\nCircular knitting: you work in a continuous round. Increases/decreases are evenly spaced around the round.</string>
    <string name="tip_pattern_repeat_pill_title">Pattern repeat counter</string>
    <string name="tip_pattern_repeat_pill_desc">This counts how many times you\'ve completed a pattern repeat section. It resets automatically based on your repeat interval. Useful for tracking cable twists, lace repeats, or color changes.</string>
    <string name="tip_needle_sizes_title">Needle size systems</string>
    <string name="tip_needle_sizes_desc">Metric (mm) is the universal standard. US sizes use a numbered system (0–50). UK/Canadian sizes use a different numbered system. Japanese sizes have their own numbering. Always check the mm size to be sure.</string>
    <string name="tip_imperial_units_title">Imperial units</string>
    <string name="tip_imperial_units_desc">When enabled, all calculators use inches instead of centimeters and yards instead of meters. Gauge is measured per 4 inches instead of per 10 cm.</string>
</resources>
